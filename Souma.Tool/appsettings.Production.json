{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Souma": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5010"
      }
    }
  },
  "EmailLogging": {
    "LogDirectory": "\\\\servidor\\logs\\email-logs\\",
    "PollingIntervalSeconds": 30
  }
}
