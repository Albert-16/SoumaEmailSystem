<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config — Configuracion de IIS para Souma.Tool (Blazor Server)

  REQUISITOS:
    1. Instalar ".NET 10 Hosting Bundle" en el servidor IIS
       https://dotnet.microsoft.com/download/dotnet/10.0
    2. Application Pool: "No Managed Code" (CLR version)
    3. El Application Pool identity debe tener permiso de LECTURA
       en la carpeta de logs (\\servidor\logs\email-logs\)
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <!--
        hostingModel="inprocess"    = Mas rapido, corre DENTRO de w3wp.exe (recomendado)
        hostingModel="outofprocess" = Corre como proceso separado (Kestrel detras de IIS)
      -->
      <aspNetCore processPath="dotnet"
                  arguments=".\Souma.Tool.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <!-- Cambiar a "Production" para produccion real -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
