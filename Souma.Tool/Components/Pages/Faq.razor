            Example = "Direccion 'usuario@dominio-invalido' no es una direccion de correo valida\nLista de destinatarios esta vacia"
        },
        new()
        {
            Title = "Adjunto excede tamano o formato no permitido",
            PipelineStep = "MAIL_ATTACHMENTS",
            Description = "El archivo adjunto supera el limite de tamano (10MB) o su extension no esta permitida. NOTA: Si el correo no tiene adjuntos, este paso continua sin error — es opcional.",
