            Description = "El correo no aparece en el dashboard de trazabilidad. Esto generalmente significa que el servicio de correo NO fue llamado correctamente o que el logging no se implemento en tu codigo.",
            Solution = "ESTAS IMPLEMENTANDO MAL EL LLAMADO AL SERVICIO DE CORREO. Verifica que: (1) tu codigo llama al endpoint POST /api/email/send, (2) el request tiene todos los campos requeridos (senderAddress, recipientAddresses, subject, body), (3) no estas atrapando la excepcion sin propagar. Si usas el servicio ASMX, verifica que la referencia al servicio web es correcta.",
            Example = ""
        }
    ];

    private sealed class FaqItem
    {
        public string Title { get; set; } = "";
        public string PipelineStep { get; set; } = "";
        public string Description { get; set; } = "";
