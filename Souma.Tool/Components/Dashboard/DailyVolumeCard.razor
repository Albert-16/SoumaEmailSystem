@* Tarjeta de volumen total de emails del día *@

<div class="card">
    <div class="card-title">Total Emails Hoy</div>
    @if (IsLoading)
    {
        <div class="skeleton skeleton-text" style="width:80px;height:2rem;"></div>
    }
    else
    {
        <div class="card-value">@TotalCount</div>
        <div class="card-subtitle">@DateLabel</div>
    }
</div>

@code {
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public string DateLabel { get; set; } = "";
    [Parameter] public bool IsLoading { get; set; }
}
