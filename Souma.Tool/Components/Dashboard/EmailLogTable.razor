@* Tabla paginada de logs de email con ordenamiento, busqueda y columna pipeline *@
@inject IJSRuntime JS

<div class="log-table-container">
    @if (IsLoading)
    {
        <div style="padding:1.5rem;">
            @for (int i = 0; i < 5; i++)
            {
                <div class="skeleton skeleton-text" style="margin-bottom:0.75rem;"></div>
            }
        </div>
    }
    else if (DisplayLogs.Count == 0)
    {
        <div style="padding:2rem;text-align:center;color:var(--text-muted);">
            No se encontraron registros con los filtros aplicados.
        </div>
    }
    else
    {
        @* Busqueda rapida inline *@
        <div style="padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);display:flex;gap:0.5rem;align-items:center;">
            <input type="text" class="table-search-input"
                   placeholder="Buscar por asunto, MessageId o CorrelationId..."
                   @bind="_searchText" @bind:event="oninput" />
            <span style="color:var(--text-muted);font-size:0.75rem;white-space:nowrap;">
                @DisplayLogs.Count registros
            </span>
        </div>

        <div style="overflow-x:auto;">
            <table class="log-table">
                <thead>
                    <tr>
                        <th class="sortable-header" @onclick='() => ToggleSort("Fecha")'>
                            Fecha @SortIcon("Fecha")
                        </th>
                        <th class="sortable-header" @onclick='() => ToggleSort("Microservicio")'>
                            Microservicio @SortIcon("Microservicio")
                        </th>
                        <th>Remitente</th>
                        <th>Asunto</th>
                        <th class="sortable-header" @onclick='() => ToggleSort("Estado")'>
                            Estado @SortIcon("Estado")
                        </th>
                        <th class="sortable-header" @onclick='() => ToggleSort("Prioridad")'>
                            Prioridad @SortIcon("Prioridad")
                        </th>
                        <th>Pipeline</th>
                        <th class="sortable-header" @onclick='() => ToggleSort("Duracion")'>
                            Duracion @SortIcon("Duracion")
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (EmailLogDto log in PagedLogs)
                    {
                        <tr @onclick="() => OnRowClicked.InvokeAsync(log)">
                            <td>@log.SentAtUtc.ToString("MM/dd HH:mm")</td>
                            <td>@log.SourceMicroservice</td>
                            <td title="@log.SenderAddress">@Truncate(log.SenderAddress, 20)</td>
                            <td title="@log.Subject">@Truncate(log.Subject, 28)</td>
                            <td><span class="status-badge status-@log.Status.ToString().ToLowerInvariant()">@log.Status</span></td>
                            <td><span class="priority-badge priority-@log.Priority.ToString().ToLowerInvariant()">@log.Priority</span></td>
                            <td>
                                @if (log.PipelineSteps is not null)
                                {
                                    PipelineStep? failed = log.PipelineSteps.FirstOrDefault(s => s.StepStatus == PipelineStepStatus.Failed);
                                    if (failed is not null)
                                    {
                                        <span class="pipeline-indicator pipeline-indicator-failed" title="@failed.StepName: @failed.Message">✕</span>
                                    }
                                    else
                                    {
                                        <span class="pipeline-indicator pipeline-indicator-ok" title="Todos los pasos OK">✓</span>
                                    }
                                }
                                else
                                {
                                    <span class="pipeline-indicator pipeline-indicator-none" title="Sin datos de pipeline">—</span>
                                }
                            </td>
                            <td>@log.DurationMs ms</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (TotalPages > 1)
        {
            <div class="pagination">
                <button class="btn btn-secondary btn-sm" disabled="@(CurrentPage <= 1)" @onclick="PreviousPage">Anterior</button>
                <span style="color:var(--text-secondary);font-size:0.82rem;">
                    Pagina @CurrentPage de @TotalPages (@DisplayLogs.Count registros)
                </span>
                <button class="btn btn-secondary btn-sm" disabled="@(CurrentPage >= TotalPages)" @onclick="NextPage">Siguiente</button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<EmailLogDto> Logs { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<EmailLogDto> OnRowClicked { get; set; }

    private const int PageSize = 50;
    private int CurrentPage = 1;
    private string _searchText = "";
    private string _sortColumn = "Fecha";
    private bool _sortAscending;

    private List<EmailLogDto> DisplayLogs
    {
        get
        {
            IEnumerable<EmailLogDto> query = Logs;

            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                string search = _searchText;
                query = query.Where(l =>
                    l.Subject.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (l.MessageId?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (l.CorrelationId?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            query = _sortColumn switch
            {
                "Fecha" => _sortAscending ? query.OrderBy(l => l.SentAtUtc) : query.OrderByDescending(l => l.SentAtUtc),
                "Microservicio" => _sortAscending ? query.OrderBy(l => l.SourceMicroservice) : query.OrderByDescending(l => l.SourceMicroservice),
                "Estado" => _sortAscending ? query.OrderBy(l => l.Status) : query.OrderByDescending(l => l.Status),
                "Prioridad" => _sortAscending ? query.OrderBy(l => l.Priority) : query.OrderByDescending(l => l.Priority),
                "Duracion" => _sortAscending ? query.OrderBy(l => l.DurationMs) : query.OrderByDescending(l => l.DurationMs),
                _ => query.OrderByDescending(l => l.SentAtUtc)
            };

            return query.ToList();
        }
    }

    private int TotalPages => (int)Math.Ceiling((double)DisplayLogs.Count / PageSize);

    private List<EmailLogDto> PagedLogs => DisplayLogs
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    protected override void OnParametersSet()
    {
        if (CurrentPage > TotalPages && TotalPages > 0)
            CurrentPage = 1;
    }

    private void ToggleSort(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = column != "Fecha";
        }
        CurrentPage = 1;
    }

    private string SortIcon(string column)
    {
        if (_sortColumn != column) return "";
        return _sortAscending ? "▲" : "▼";
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1) CurrentPage--;
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages) CurrentPage++;
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length > maxLength ? string.Concat(text.AsSpan(0, maxLength - 3), "...") : text;
}
