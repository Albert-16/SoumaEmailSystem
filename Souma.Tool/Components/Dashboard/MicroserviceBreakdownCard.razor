@* Tarjeta de desglose por microservicio de origen *@

<div class="card">
    <div class="card-title">Por Microservicio</div>
    @if (IsLoading)
    {
        <div class="skeleton skeleton-text" style="width:100%;height:3rem;"></div>
    }
    else if (Breakdown.Count == 0)
    {
        <div class="card-subtitle">Sin datos</div>
    }
    else
    {
        <ul class="recipient-list" style="margin-top:0.5rem;">
            @foreach (var item in Breakdown)
            {
                <li>
                    <span style="color:var(--text-primary);">@item.Key</span>
                    <span class="recipient-count">@item.Value</span>
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter] public Dictionary<string, int> Breakdown { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }
}
