{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EmailLogging": {
    "LogDirectory": "./email-logs",
    "MaxFileSizeMb": 10,
    "RetentionDays": 30,
    "EnableCompression": false,
    "FallbackDirectory": "./email-logs-fallback",
    "PollingIntervalSeconds": 30
  }
}
